# Copy this file to .env and set real values.
# .env is ignored by git in this project.

SECRET_KEY=dev-change-me

# Optional DB override (PostgreSQL example):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USE_TLS=1
MAIL_USERNAME=YOUR_MAILTRAP_USERNAME
MAIL_PASSWORD=YOUR_MAILTRAP_PASSWORD
MAIL_DEFAULT_SENDER=Private Person <hello@skolniknihovnats.com>

# Optional token expiry settings
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
PASSWORD_RESET_TOKEN_TTL_HOURS=2
